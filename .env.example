# ============================================================
# Polymarket Copy-Trading Bot — файл окружения
# ============================================================
# 1. Скопируйте:  copy .env.example .env   (Windows)
#                  cp .env.example .env      (Linux/Mac)
# 2. Заполните реальными значениями
# 3. НИКОГДА не коммитьте .env в git!
# ============================================================

# ---- Режим работы ----
# MODE=LIVE + DRY_RUN=true → виртуальная торговля с трекингом позиций
# MODE=LIVE + DRY_RUN=false → РЕАЛЬНАЯ торговля (осторожно!)
# MODE=SIGNAL_ONLY → только сигналы в лог, без открытия позиций
MODE=LIVE
DRY_RUN=true

# ---- Виртуальный депозит (только при DRY_RUN=true) ----
VIRTUAL_DEPOSIT_USD=100.0

# ---- Telegram Bot ----
# Создать бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890
# Ваш chat_id (получить через @userinfobot)
TELEGRAM_CHAT_ID=123456789

# ---- Кошелёк Polygon (для реальной торговли) ----
# Приватный ключ (без 0x, hex строка 64 символа)
WALLET_PRIVATE_KEY=
# Публичный адрес кошелька (checksummed 0x...)
WALLET_ADDRESS=

# ---- API ключи Polymarket CLOB (для реальной торговли) ----
# Получить на: https://polymarket.com → Profile → API Keys
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ---- Параметры риска ----
# Глобальный фильтр цены (fallback — per-trader overrides в config.py важнее)
# sayber: 0.20–0.75 | gatorr: 0.25–0.80 | WizzleGizzle: 0.01–0.15
MIN_ENTRY_PRICE=0.05
MAX_ENTRY_PRICE=0.95

# Размеры позиций по сигналам
HIGH_POSITION_USD=5.0
MEDIUM_POSITION_USD=3.0
MAX_POSITION_USD=10.0
MIN_COPY_SIZE_USD=1.0

# Лимиты
MAX_OPEN_POSITIONS=3
MAX_TOTAL_EXPOSURE_USD=20.0
DAILY_LOSS_LIMIT_USD=6.0

# Стоп-лосс / тейк-профит
STOP_LOSS_PERCENT=0.80
TAKE_PROFIT_1_PCT=0.20
TAKE_PROFIT_2_PCT=0.40

# Опрос API
POLL_INTERVAL_SEC=30

# ---- Сеть ----
POLYGON_RPC=https://polygon-rpc.com

# ---- Логирование ----
LOG_LEVEL=INFO

# ---- Дашборд ----
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
