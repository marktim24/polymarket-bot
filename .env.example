# ============================================================
# Polymarket Copy-Trading Bot — пример файла окружения
# ============================================================
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Заполните реальными значениями
# 3. НИКОГДА не коммитьте .env в git!
# ============================================================

# ---- Кошелёк Polygon ----
# Приватный ключ (без 0x, hex строка 64 символа)
WALLET_PRIVATE_KEY=ваш_приватный_ключ_без_0x_здесь

# Публичный адрес кошелька (checksummed 0x...)
WALLET_ADDRESS=0xВашАдресКошелька

# ---- API ключи Polymarket CLOB ----
# Получить на: https://polymarket.com → Profile → API Keys
CLOB_API_KEY=ваш_clob_api_key
CLOB_API_SECRET=ваш_clob_api_secret
CLOB_API_PASSPHRASE=ваш_clob_passphrase

# ---- Telegram Bot ----
# Создать бота: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890
# Ваш chat_id (получить через @userinfobot)
TELEGRAM_CHAT_ID=123456789

# ---- Режим работы ----
# DRY_RUN=true  → только логи, без реальных ордеров (РЕКОМЕНДУЕТСЯ для старта)
# DRY_RUN=false → реальная торговля (БУДЬТЕ ОСТОРОЖНЫ!)
DRY_RUN=true

# ---- Параметры риска (опционально, есть дефолты в config.py) ----
MAX_POSITION_USD=10.0
MIN_ENTRY_PRICE=0.05
MAX_ENTRY_PRICE=0.70
COPY_RATIO=0.5
MIN_COPY_SIZE_USD=1.0
MAX_OPEN_POSITIONS=20
POLL_INTERVAL_SEC=30
STOP_LOSS_PERCENT=0.80

# ---- Сеть ----
# RPC для Polygon (можно заменить на Alchemy/Infura для надёжности)
POLYGON_RPC=https://polygon-rpc.com
# Альтернативы:
# POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/ВАШ_ALCHEMY_KEY
# POLYGON_RPC=https://polygon-mainnet.infura.io/v3/ВАШ_INFURA_KEY

# ---- Логирование ----
LOG_LEVEL=INFO
# Варианты: DEBUG, INFO, WARNING, ERROR

# ---- Дашборд ----
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
